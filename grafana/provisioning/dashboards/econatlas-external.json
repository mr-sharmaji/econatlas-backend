{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "\ud83c\udf10 External API health",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Outbound call rate by provider",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (provider) (rate(external_api_requests_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Non-2xx rate by provider",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (provider) (rate(external_api_requests_total{status!=\"ok\"}[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Rate-limit events (429 / 503) per hour",
      "type": "bargauge",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "(sum by (provider) (increase(external_api_rate_limited_total[1h]))) OR vector(0)",
          "legendFormat": "{{provider}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "p95 external API duration by provider",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(external_api_duration_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error rate % by (provider, endpoint)",
      "type": "table",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value": "err %"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "100 * sum by (provider, endpoint) (rate(external_api_requests_total{status!=\"ok\"}[15m])) / clamp_min(sum by (provider, endpoint) (rate(external_api_requests_total[15m])), 0.0001)",
          "legendFormat": "{{provider}} {{endpoint}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
