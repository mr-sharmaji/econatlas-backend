    {
      "title": "Windows CPU %",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - avg(rate(windows_cpu_time_total{mode=\"idle\"}[1m]))) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Windows Memory %",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 5,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - windows_memory_available_bytes / windows_memory_physical_total_bytes) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Windows Memory used / total",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 5,
        "x": 10,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "decimals": 1
        }
      },
      "targets": [
        {
          "expr": "(windows_memory_physical_total_bytes - windows_memory_available_bytes) / 1024 / 1024 / 1024",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "windows_memory_physical_total_bytes / 1024 / 1024 / 1024",
          "legendFormat": "Total",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Windows Disk % per volume",
      "type": "bargauge",
      "gridPos": {
        "h": 5,
        "w": 9,
        "x": 15,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "lcd"
      },
      "targets": [
        {
          "expr": "(1 - windows_logical_disk_free_bytes / windows_logical_disk_size_bytes) * 100",
          "legendFormat": "{{volume}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Windows CPU% over time",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - avg(rate(windows_cpu_time_total{mode=\"idle\"}[1m]))) * 100",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "avg(rate(windows_cpu_time_total{mode=\"user\"}[1m])) * 100",
          "legendFormat": "User",
          "refId": "B"
        },
        {
          "expr": "avg(rate(windows_cpu_time_total{mode=\"privileged\"}[1m])) * 100",
          "legendFormat": "Kernel",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Windows Network throughput",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 12,
