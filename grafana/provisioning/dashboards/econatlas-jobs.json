      },
      "targets": [
        {
          "expr": "sum by (job_name) (rate(jobs_started_total[5m]))",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Job duration p95 by job",
