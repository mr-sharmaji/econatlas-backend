    {
      "title": "Job Run Log (live from DB)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT job_name, to_char(last_success_at AT TIME ZONE 'Asia/Kolkata', 'DD Mon HH24:MI') AS last_success_ist, ROUND(last_duration_s::numeric, 1) AS duration_s, success_count, consecutive_failures, COALESCE(LEFT(last_error, 80), '') AS last_error, last_trigger FROM job_run_log ORDER BY last_success_at DESC NULLS LAST",
          "format": "table",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      }
    },
    {
      "title": "Job throughput (started/s)",
      "type": "timeseries",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
